# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # From Supabase project settings → API

# App URL (used for tracking pixels, unsubscribe links, OAuth callbacks)
NEXT_PUBLIC_APP_URL=         # e.g. https://crm-for-saas.vercel.app

# Google OAuth for Gmail API (separate from Supabase Auth login)
GOOGLE_CLIENT_ID=            # From Google Cloud Console
GOOGLE_CLIENT_SECRET=        # From Google Cloud Console

# Encryption key for Gmail tokens (AES-256-GCM)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Cron job secret for scheduled tasks
# Generate with: openssl rand -hex 32
CRON_SECRET=

# Custom tracking domain for email open/click tracking (optional)
# If not set, falls back to NEXT_PUBLIC_APP_URL
TRACKING_DOMAIN=

# Google Maps Platform — Field routes feature.
# Single key with Routes API + Geocoding API + Maps JavaScript API enabled.
# Server-side only — DO NOT expose on NEXT_PUBLIC_*.
GOOGLE_MAPS_API_KEY=

# Default origin for the field-route generator (Hans, Vällingby).
ROUTE_DEFAULT_ORIGIN_ADDRESS=Markvägen 23, 162 71 Vällingby
ROUTE_DEFAULT_ORIGIN_LAT=59.3625
ROUTE_DEFAULT_ORIGIN_LNG=17.8722

# --- Reviews dashboard sync (/ceo/reviews, /api/cron/sync-reviews) ---
# Trustpilot public Business Units API key. Aggregate rating + count + public
# reviews; no OAuth needed. From Trustpilot Business → Integrations →
# Developers → APIs → Your Applications.
TRUSTPILOT_API_KEY=
# Optional — pin the business unit id to skip the /find lookup.
TRUSTPILOT_BUSINESS_UNIT_ID=
# Optional — domain used to resolve the business unit id (default wrenchlane.com).
TRUSTPILOT_DOMAIN=

# Google Business Profile review sync — DORMANT until the GBP API access
# request is approved (quota stays 0 until then). Set GBP_REVIEWS_ENABLED=1
# plus the OAuth refresh token (business.manage scope) and pinned IDs to turn on.
GBP_REVIEWS_ENABLED=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
GBP_ACCOUNT_ID=
GBP_LOCATION_ID=
